# ============================================================
# .env.example — Environment Variables Template
# Copy this file to .env and fill in your values
# .env is NEVER committed to git (see .gitignore)
# ============================================================

# --- Email Password (for recruiter email drafts) ---
# Use an App Password if you have 2FA enabled
EMAIL_PASSWORD=your_gmail_app_password_here

# --- Telegram Bot (optional) ---
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- LinkedIn (optional, for Selenium scraping) ---
LINKEDIN_EMAIL=your_linkedin_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password
