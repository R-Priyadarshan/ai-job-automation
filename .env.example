# ============================================================
# .env.example — Environment Variables Template
# Copy this file to .env and fill in your values
# .env is NEVER committed to git (see .gitignore)
# ============================================================

# --- Gmail App Password (REQUIRED for auto cold-mail) ---
# Steps to get this:
# 1. Enable 2-Step Verification on your Gmail account
# 2. Go to: myaccount.google.com → Security → App Passwords
# 3. Create App Password for "Mail" → copy the 16-char password
# 4. Paste it below (no spaces)
EMAIL_PASSWORD=your_16_char_gmail_app_password

# --- Telegram Bot (optional) ---
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- LinkedIn (optional, for Selenium scraping) ---
LINKEDIN_EMAIL=your_linkedin_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password
